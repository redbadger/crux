mod lib '../../../lib.just'

default: dev

# --------------------------------------------------------------------------
# Development
# --------------------------------------------------------------------------

# checks required tools are installed
doctor:
    @echo '{{ style("command") }}doctor:{{ NORMAL }}'
    @just lib::check-web-wasm

# auto-fix formatting issues
fix: build
    @echo '{{ style("command") }}fix:{{ NORMAL }}'
    pnpm exec eslint --fix .

# validate lint
check:
    @echo '{{ style("command") }}check:{{ NORMAL }}'
    @echo "  No lint configured"

# generate types for typescript
typegen:
    @echo '{{ style("command") }}typegen:{{ NORMAL }}'
    RUST_LOG=info cargo run \
        --package shared \
        --bin codegen \
        --features codegen,facet_typegen \
        -- \
            --language typescript \
            --output-dir generated/types

# build wasm package
[working-directory('../shared')]
wasm:
    @echo '{{ style("command") }}wasm:{{ NORMAL }}'
    boltffi pack wasm
    @just lib::fix-boltffi-wasm-package ../web-nextjs/generated/pkg/package.json

# install npm dependencies
install:
    @echo '{{ style("command") }}install:{{ NORMAL }}'
    pnpm install

# build the project
build: typegen wasm install
    @echo '{{ style("command") }}build:{{ NORMAL }}'
    pnpm build

# run tests
test:
    @echo '{{ style("command") }}test:{{ NORMAL }}'
    @echo "  No tests configured"

# clean build artifacts
clean:
    @echo '{{ style("command") }}clean:{{ NORMAL }}'
    cargo clean
    rm -rf generated .next node_modules

# update pnpm dependencies to latest
update-pnpm-deps: typegen wasm
    @echo '{{ style("command") }}update-pnpm-deps:{{ NORMAL }}'
    pnpm update

# local development workflow
dev: fix check build test

# CI workflow
ci: check build test

# serve the app locally
serve: typegen wasm install
    @echo '{{ style("command") }}serve:{{ NORMAL }}'
    pnpm dev
