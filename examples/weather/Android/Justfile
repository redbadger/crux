mod lib '../../../lib.just'
mod wlib '../weather-lib.just'

default: dev

# --------------------------------------------------------------------------
# Development
# --------------------------------------------------------------------------

# checks required tools are installed
doctor:
    @echo '{{ style("command") }}doctor:{{ NORMAL }}'
    @just lib::check-android
    @just wlib::check-env

# copies API key from .env to local.properties
[script('sh'), unix]
setup:
    set -euo pipefail
    echo '{{ style("command") }}setup:{{ NORMAL }}'
    . ../.env
    if [ -z "${OPENWEATHER_API_KEY:-}" ]; then
        echo "  ERROR: OPENWEATHER_API_KEY not set in ../.env"
        exit 1
    fi
    touch local.properties
    if grep -q '^OPENWEATHER_API_KEY=' local.properties 2>/dev/null; then
        tmp=$(mktemp)
        sed "s/^OPENWEATHER_API_KEY=.*/OPENWEATHER_API_KEY=${OPENWEATHER_API_KEY}/" local.properties > "$tmp"
        mv "$tmp" local.properties
    else
        echo "OPENWEATHER_API_KEY=${OPENWEATHER_API_KEY}" >> local.properties
    fi
    echo "  API key written to local.properties"

[script('powershell'), windows]
setup:
    Write-Host '{{ style("command") }}setup:{{ NORMAL }}'
    $envFile = Join-Path ".." ".env"
    if (-not (Test-Path $envFile)) {
        Write-Error "  ERROR: ../.env not found"
        exit 1
    }
    $key = Get-Content $envFile |
        Where-Object { $_ -match '^\s*(export\s+)?OPENWEATHER_API_KEY=(.+)$' } |
        ForEach-Object { $Matches[2] }
    if (-not $key) {
        Write-Error "  ERROR: OPENWEATHER_API_KEY not set in ../.env"
        exit 1
    }
    if (-not (Test-Path "local.properties")) {
        New-Item -ItemType File -Path "local.properties" | Out-Null
    }
    $content = Get-Content "local.properties"
    if ($content -match 'OPENWEATHER_API_KEY=') {
        $content = $content -replace '^OPENWEATHER_API_KEY=.*', "OPENWEATHER_API_KEY=$key"
        Set-Content "local.properties" $content
    } else {
        Add-Content "local.properties" "OPENWEATHER_API_KEY=$key"
    }
    Write-Host "  API key written to local.properties"

# install Android Rust cross-compilation targets
install-targets:
    @echo '{{ style("command") }}install-targets:{{ NORMAL }}'
    TOOLCHAIN="${RUSTUP_TOOLCHAIN:-$(rustup show active-toolchain | awk '{print $1}')}" ; \
    echo "  Toolchain: $TOOLCHAIN" ; \
    rustup target add --toolchain "$TOOLCHAIN" \
        aarch64-linux-android \
        armv7-linux-androideabi \
        i686-linux-android \
        x86_64-linux-android

# auto-fix formatting issues
fix:
    @echo '{{ style("command") }}fix:{{ NORMAL }}'
    @echo "  No auto-fix configured for Android Gradle sources"

# validate Android lint checks (requires generated types)
check: typegen
    @echo '{{ style("command") }}check:{{ NORMAL }}'
    ./gradlew --no-daemon :app:lintDebug

# build the shared library so uniffi-bindgen can inspect it
build-shared:
    @echo '{{ style("command") }}build-shared:{{ NORMAL }}'
    cargo build --features uniffi

# generate Kotlin types and uniffi bindings
typegen: build-shared
    @echo '{{ style("command") }}typegen:{{ NORMAL }}'
    RUST_LOG=info cargo run \
        --package shared \
        --bin codegen \
        --features codegen,facet_typegen \
        -- \
            --language kotlin \
            --output-dir generated

# build the Android debug APK (generates types first)
build: typegen
    @echo '{{ style("command") }}build:{{ NORMAL }}'
    ./gradlew --no-daemon :app:assembleDebug

# run Android JVM unit tests
test:
    @echo '{{ style("command") }}test:{{ NORMAL }}'
    ./gradlew --no-daemon :app:testDebugUnitTest

# remove build artifacts
clean:
    @echo '{{ style("command") }}clean:{{ NORMAL }}'
    ./gradlew --no-daemon clean
    rm -rf generated

# local development workflow
dev: setup fix check build test

# CI workflow
ci: check build test

# open in Android Studio
open:
    @just lib::open-android-studio
