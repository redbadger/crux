<?xml version="1.0" encoding="utf-8"?>
<!--
  Adds a local NuGet feed at generated/nuget so MSBuild can restore
  CounterApp.Shared.Ffi (built and packed by `boltffi pack csharp`).
  Inherited sources (nuget.org for everything else) are kept untouched.
-->
<configuration>
  <packageSources>
    <add key="boltffi-local" value="generated/nuget" />
  </packageSources>
</configuration>
