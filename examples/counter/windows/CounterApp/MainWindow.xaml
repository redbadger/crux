<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CounterApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Counter">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <TextBlock
                Text="{x:Bind ViewModel.View.Count, Mode=OneWay}"
                FontSize="24"
                HorizontalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <Button Content="Reset" Command="{x:Bind ViewModel.ResetCommand}" />
                <Button Content="Increment" Command="{x:Bind ViewModel.IncrementCommand}" />
                <Button Content="Decrement" Command="{x:Bind ViewModel.DecrementCommand}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
